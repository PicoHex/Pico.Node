[*.cs]

# --- Unused code detection ---
dotnet_diagnostic.IDE0005.severity = warning          # unnecessary using directive
dotnet_diagnostic.IDE0051.severity = warning          # unused private member
dotnet_diagnostic.IDE0052.severity = warning          # unread private member
dotnet_diagnostic.IDE0060.severity = warning          # unused parameter
dotnet_diagnostic.CA1822.severity = suggestion        # member can be static
dotnet_diagnostic.CA1823.severity = suggestion        # unused private field
dotnet_diagnostic.CA1812.severity = suggestion        # uninstantiated internal class

# --- Namespace style (C# 10+) ---
csharp_style_namespace_declarations = file_scoped:suggestion

# --- Accessibility ---
dotnet_style_require_accessibility_modifiers = always:suggestion

# --- Formatting ---
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
